{
  "$schema": "https://opencode.ai/config.json",

  // Global model — used by the default primary agent
  "model": "opencode/deepseek-v4-flash-free",

  // Small model — used for lightweight / fast tasks
  "small_model": "opencode/deepseek-v4-flash-free",

  // Per-agent model overrides — applies to every built-in role
  "agent": {
    "build": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "plan": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "general": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "explore": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "librarian": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "oracle": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "metis": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "momus": {
      "model": "opencode/deepseek-v4-flash-free"
    }
  }
}
